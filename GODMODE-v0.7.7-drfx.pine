barColorMode = input.string("Scalper Trend", "Bar Color Priority",
     options=["Scalper Trend", "RAPTOR MACD", "Elite Algo", "None"],
     group='🎨 BAR COLORS',
     tooltip='Select which system controls bar coloring.\n• Scalper Trend: Green/Red trend + Purple sideways\n• RAPTOR MACD: MACD-based momentum colors\n• Elite Algo: Range filter trend colors\n• None: Default chart colors')

// ═══════════════════════════════════════════════════════════════════════════
// 📲 DASHBOARD SETTINGS
// ═══════════════════════════════════════════════════════════════════════════

dashboardEnabled = input.bool(true, '📲 Show Dashboard', group='📲 DASHBOARD',
     tooltip='Display the information dashboard with system status and performance stats.')

dashboardLocation = input.string("Top Right", "Position", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group='📲 DASHBOARD')

dashboardMode = input.string("Normal", "Display Mode", options=["Compact", "Normal"], group='📲 DASHBOARD',
     tooltip='Compact = Mobile-friendly minimal view, Normal = Full information display')

dashboardSize = input.string("Small", "Dashboard Size", options=["Small", "Normal", "Large"], group='📲 DASHBOARD')

dashboardTransparency = input.int(15, "Background Transparency", minval=0, maxval=100, group='📲 DASHBOARD',
     tooltip='0 = Solid background, 100 = Fully transparent')

dashboardStyle = input.string("Dark Pro", "Theme", options=["Dark Pro", "Light", "Neon"], group='📲 DASHBOARD',
