# ============================================================================
#  Quantum Chat — environment configuration (DNS-resilient emergency messenger)
#  Copy to /etc/quantum-chat/quantum-chat.env and lock to 0600 root:quantum-chat.
#  The installer generates secrets and fills the prompted values for you.
# ============================================================================

# --- Identity / DNS zone ----------------------------------------------------
# The dedicated subdomain you delegate to THIS server (authoritative).
QUANTUM_CHAT_DOMAIN=qc.example.com
# Optional comma-separated extra/backup zones for censorship resistance.
QUANTUM_CHAT_EXTRA_DOMAINS=
# Public IPv4 of this node — published as the apex A record / NS glue.
QUANTUM_CHAT_PUBLIC_IP=203.0.113.10
# Comma-separated authoritative nameserver hostnames (apex NS answers).
QUANTUM_CHAT_NS_NAMES=ns1.qc.example.com
# Admin contact (SOA RName + operator notices). Not published to users.
QUANTUM_CHAT_ADMIN_EMAIL=admin@example.com

# --- Listeners --------------------------------------------------------------
QUANTUM_CHAT_PORT=53
QUANTUM_CHAT_BIND_ADDR=0.0.0.0
QUANTUM_CHAT_TCP_ENABLED=true
QUANTUM_CHAT_UDP_ENABLED=true

# --- Storage ----------------------------------------------------------------
# ram      : RAM-only (default). Nothing on disk; everything lost on restart.
# postgres : durable mode (schema in migrations/001_quantum_chat_schema.sql).
#            Set QUANTUM_CHAT_POSTGRES_URL below. If Postgres is unreachable the
#            node logs a warning and falls back to RAM so messaging stays up.
QUANTUM_CHAT_STORAGE_MODE=ram
QUANTUM_CHAT_POSTGRES_URL=
QUANTUM_CHAT_REDIS_URL=

# --- Message policy ---------------------------------------------------------
# How long an undelivered encrypted message is retained before auto-delete.
QUANTUM_CHAT_MESSAGE_TTL_MINUTES=1440
# Max reassembled envelope size (bytes). Larger = more DNS queries per message.
QUANTUM_CHAT_MAX_MESSAGE_SIZE=2048
# Per-source query budget (token bucket). Tune for abuse vs. usability.
QUANTUM_CHAT_RATE_LIMIT_PER_MINUTE=30

# --- Logging ----------------------------------------------------------------
# false = minimal-metadata operation (recommended). Message CONTENT is never
# logged regardless. true enables operational audit events (register/enqueue).
QUANTUM_CHAT_ENABLE_LOGS=false

# --- Secrets (generated by the installer; keep out of version control) ------
# Bearer token for any future local admin/status endpoint.
QUANTUM_CHAT_ADMIN_TOKEN=
# Reserved for at-rest wrapping in durable mode / future features.
QUANTUM_CHAT_SECRET_KEY=

# --- Client resolver bank ---------------------------------------------------
# Recursive resolvers the CLIENT scatters queries across (defeats single-
# resolver blocking). Consumed by the client/frontend, not the server.
QUANTUM_CHAT_RESOLVER_BANK=1.1.1.1,8.8.8.8,9.9.9.9,208.67.222.222
